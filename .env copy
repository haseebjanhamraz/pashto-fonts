# General Environment config
NODE_ENV=development
PORT=4000

# Database Connection (PostgreSQL inside Docker)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pashto_fonts?schema=public

# Redis Connection (Docker)
REDIS_URL=redis://localhost:6379

# Object Storage Configuration (MinIO in local, Cloudflare R2 in prod)
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=pashto-fonts
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio123
S3_PUBLIC_BASE_URL=http://localhost:9000/pashto-fonts

# Security and Auth Secrets
JWT_SECRET=super_secure_jwt_secret_please_change_in_production
COOKIE_SECRET=super_secure_cookie_secret_please_change_in_production

# URL Configurations
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Application Limits
MAX_FONT_UPLOAD_MB=20
